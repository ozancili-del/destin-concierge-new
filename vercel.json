{
  "redirects": [
    {
      "source": "/snowbird",
      "destination": "/",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "sunbirds.destincondogetaways.com"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/snowbird",
      "permanent": false,
      "has": [
        {
          "type": "host",
          "value": "sunbirds.destincondogetaways.com"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/offer",
      "permanent": false,
      "has": [
        {
          "type": "host",
          "value": "offer.destincondogetaways.com"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/rate-finder.html",
      "permanent": false,
      "has": [
        {
          "type": "host",
          "value": "deals.destincondogetaways.com"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/destin-hub",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "explore.destincondogetaways.com"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/guestview",
      "permanent": false,
      "has": [
        {
          "type": "host",
          "value": "guestview.destincondogetaways.com"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/app",
      "permanent": false,
      "has": [
        {
          "type": "host",
          "value": "app.destincondogetaways.com"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/snowbird",
      "has": [
        {
          "type": "host",
          "value": "sunbirds.destincondogetaways.com"
        }
      ]
    },
    {
      "source": "/tv-707.html",
      "destination": "/tv-707.html"
    },
    {
      "source": "/tv-1006.html",
      "destination": "/tv-1006.html"
    },
    {
      "source": "/destin-hub.html",
      "destination": "/destin-hub"
    }
  ],
  "crons": [
    {
      "path": "/api/price-snapshot",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/thermostat",
      "schedule": "0 12 * * *"
    }
  ]
}
